rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: rooms
    // Fields:
    //   - videoUrl: string (required)
    //   - status: string (required, 'playing' | 'paused')
    //   - currentTime: number (required)
    //   - lastUpdated: number (required)
    //   - hostId: string (required)
    //
    // Collection: rooms/{roomId}/messages
    // Fields:
    //   - roomId: string (required)
    //   - userId: string (required)
    //   - userName: string (required)
    //   - text: string (required)
    //   - timestamp: number (required)
    //
    // Collection: rooms/{roomId}/reactions
    // Fields:
    //   - roomId: string (required)
    //   - userId: string (required)
    //   - emoji: string (required)
    //   - timestamp: number (required)
    //
    // Collection: users
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (required)
    //   - photoURL: string (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidRoom(data) {
      return data.videoUrl is string &&
             data.status in ['playing', 'paused'] &&
             data.currentTime is number &&
             data.lastUpdated is number &&
             data.hostId is string;
    }

    function isValidMessage(data) {
      return data.roomId is string &&
             data.userId == request.auth.uid &&
             data.userName is string &&
             data.text is string && data.text.size() > 0 && data.text.size() < 1000 &&
             data.timestamp is number;
    }

    function isValidReaction(data) {
      return data.roomId is string &&
             data.userId == request.auth.uid &&
             data.emoji is string &&
             data.timestamp is number;
    }

    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() > 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /rooms/{roomId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidRoom(request.resource.data);
      allow update: if isAuthenticated() && isValidRoom(request.resource.data);
      
      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidMessage(request.resource.data);
      }

      match /reactions/{reactionId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidReaction(request.resource.data);
      }
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
