rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    // Rooms and their subcollections (messages, reactions, presence)
    match /rooms/{roomId} {
      allow read, write: if request.time < timestamp.date(2026, 5, 10);
      
      match /{subcollection=**} {
        allow read, write: if request.time < timestamp.date(2026, 5, 10);
      }
    }
    
    // Events collection
    match /events/{eventId} {
      allow read: if true;
      allow write: if request.time < timestamp.date(2026, 5, 10);
    }
    
    // Subscribers collection
    match /subscribers/{subscriberId} {
      allow read: if request.time < timestamp.date(2026, 5, 10);
      allow create: if request.time < timestamp.date(2026, 5, 10);
    }
    
    // Test collection
    match /test/{document=**} {
      allow read: if true;
    }
  }
}
